---
import BaseLayout from '../layouts/BaseLayout.astro';

// Set to true and place a headshot image at public/images/headshot.jpg
const SHOW_PHOTO = true;
---

<BaseLayout title="About | David Glass" description="About David Glass — software developer specializing in cybersecurity, penetration testing, and cloud security architecture.">
  <div class="container">
    <div class="page-header">
      <h1>About</h1>
    </div>

    <div class={SHOW_PHOTO ? 'about-intro-split' : 'about-section'}>
      {SHOW_PHOTO && (
        <div class="about-photo">
          <img src="/images/headshot.jpg" alt="David Glass" />
        </div>
      )}
      <div>
        <h2>Who I Am</h2>
        <p>
          I'm David Glass, a software developer turned cybersecurity professional based in Chicago. I spent years building software — iOS apps, desktop tools, web apps, mathematical research projects — before shifting my focus to security. I completed Northwestern's cybersecurity program, where I trained in penetration testing, network defense, and threat analysis. Offensive security is where I do my best work: finding vulnerabilities before someone else does.
        </p>
      </div>
    </div>

    <div class="about-section">
      <h2>Cybersecurity Projects</h2>
      <p>
        My security work covers penetration testing, cloud architecture, and building practical security tools. I've designed secure Azure deployments, built an offline "Have I Been Pwned?" service, and worked through real-world attack scenarios. See the <a href="/projects">projects page</a> for specifics.
      </p>
    </div>

    <div class="about-section">
      <h2>Beyond Cybersecurity</h2>
      <p>
        I've been building things for a long time. Here are some projects from before (and alongside) the security work:
      </p>
      <ul>
        <li><a href="/tools/passwords">Password Lab</a> &mdash; Generate secure passwords and test their strength</li>
        <li><a href="/tools/encryption">Encryption Suite</a> &mdash; AES and RSA encryption with built-in key pair generation</li>
        <li><a href="/tools/base-converter">Base Converter</a> &mdash; Convert numbers between bases 1 through 36</li>
        <li><a href="/coin-problem">Coin Problem</a> &mdash; Mathematical research on the Frobenius Coin Problem, backed by a database of ~60 million sets</li>
        <li><a href="/resume-builder">Resume Builder</a> &mdash; A desktop app for crafting customized, professional resumes</li>
      </ul>
    </div>

    <div class="about-section">
      <h2>Contact</h2>
      <div class="contact-grid">
        <div class="contact-item">
          <div class="label">Email</div>
          <a href="mailto:dglass2525@gmail.com">dglass2525@gmail.com</a>
        </div>
        <div class="contact-item">
          <div class="label">GitHub</div>
          <a href="https://github.com/dglass710" target="_blank" rel="noopener">github.com/dglass710</a>
        </div>
        <div class="contact-item">
          <div class="label">LinkedIn</div>
          <a href="https://www.linkedin.com/in/david-a-glass/" target="_blank" rel="noopener">linkedin.com/in/david-a-glass</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
