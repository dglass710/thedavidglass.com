---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const devSeries = posts
  .filter((p) => p.data.categories?.includes('Bootcamp Blog'))
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

function getExcerpt(body: string, length = 150): string {
  const cleaned = body
    .replace(/#{1,6}\s/g, '')
    .replace(/\*\*/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_~`]/g, '')
    .trim();
  return cleaned.length > length ? cleaned.slice(0, length) + '...' : cleaned;
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Cybersecurity Development Series | David Glass" description="Follow David Glass's cybersecurity development series — hands-on projects, tools, and security research.">
  <div class="container">
    <div class="page-header">
      <h1>Cybersecurity Development Series</h1>
      <p>Documenting my professional development in offensive security, network defense, and threat analysis.</p>
    </div>

    <div class="card-grid anim-in" style="--delay: 0.05s">
      {devSeries.map((post) => (
        <article class="card">
          <h3><a href={`/blog/${post.data.slug}`}>{post.data.title}</a></h3>
          <p class="meta">{formatDate(post.data.date)}</p>
          <p class="excerpt">{getExcerpt(post.body || '', 150)}</p>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .anim-in {
    animation: fadeUp 0.5s ease both;
    animation-delay: var(--delay, 0s);
  }
</style>
