---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const devSeries = posts
  .filter((p) => p.data.categories?.includes('Bootcamp Blog'))
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const caseStudies = posts
  .filter((p) => p.data.categories?.includes('projects'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function getExcerpt(body: string, length = 150): string {
  const cleaned = body
    .replace(/#{1,6}\s/g, '')
    .replace(/\*\*/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_~`]/g, '')
    .trim();
  return cleaned.length > length ? cleaned.slice(0, length) + '...' : cleaned;
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Blog | David Glass">
  <div class="container">
    <div class="page-header">
      <h1>Blog</h1>
      <p>Cybersecurity case studies, development insights, and professional growth.</p>
    </div>

    <section class="section anim-in" style="--delay: 0.05s">
      <div class="section-header">
        <h2>Case Studies</h2>
      </div>
      <p class="section-description">Hands-on security assessments, architecture projects, and technical deep dives.</p>
      <div class="card-grid">
        {caseStudies.map((post) => (
          <article class="card">
            <h3><a href={`/blog/${post.data.slug}`}>{post.data.title}</a></h3>
            <p class="meta">{formatDate(post.data.date)}</p>
            <p class="excerpt">{getExcerpt(post.body || '', 150)}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section anim-in" style="--delay: 0.15s">
      <div class="section-header">
        <h2>Cybersecurity Development Series</h2>
      </div>
      <p class="section-description">Documenting my professional development in offensive security, network defense, and threat analysis.</p>
      <div class="card-grid">
        {devSeries.map((post) => (
          <article class="card">
            <h3><a href={`/blog/${post.data.slug}`}>{post.data.title}</a></h3>
            <p class="meta">{formatDate(post.data.date)}</p>
            <p class="excerpt">{getExcerpt(post.body || '', 150)}</p>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .anim-in {
    animation: fadeUp 0.5s ease both;
    animation-delay: var(--delay, 0s);
  }
  .section-description {
    color: var(--text-muted);
    font-family: var(--font-body);
    font-size: 0.9rem;
    margin-top: -1.25rem;
    margin-bottom: 1.5rem;
  }
</style>
