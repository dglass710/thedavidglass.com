---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const pages = await getCollection('pages');
const coinPage = pages.find((p) => p.data.slug === 'coin-problem');

let Content: any = null;
if (coinPage) {
  const rendered = await render(coinPage);
  Content = rendered.Content;
}
---

<BaseLayout title="Coin Problem | David Glass" description="Research on the Frobenius Coin Problem — exploring symmetry in four-denomination sets with a database of 60 million entries.">
  <div class="container">
    <div class="page-header">
      <h1>Coin Problem</h1>
      <p>Mathematical research on the Frobenius Coin Problem and symmetry in number theory.</p>
    </div>
    <div class="prose">
      {Content && <Content />}
    </div>
  </div>
</BaseLayout>
