---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const caseStudies = allPosts
  .filter((p) => p.data.categories?.includes('projects'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const devSeries = allPosts
  .filter((p) => p.data.categories?.includes('Bootcamp Blog'))
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())
  .slice(0, 4);

function getExcerpt(body: string, length = 150): string {
  const cleaned = body
    .replace(/#{1,6}\s/g, '')
    .replace(/\*\*/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_~`]/g, '')
    .trim();
  return cleaned.length > length ? cleaned.slice(0, length) + '...' : cleaned;
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="David Glass | Software Developer & Cybersecurity Professional">
  <section class="hero">
    <h1>David Glass</h1>
    <p class="subtitle">Software Developer | Cybersecurity Professional</p>
    <p class="tagline">
      Building secure systems and breaking insecure ones. Based in Chicago, focused on offensive security and software development.
    </p>
    <div class="hero-buttons">
      <a href="/projects" class="btn btn-primary">View Projects</a>
      <a href="/blog" class="btn btn-outline">Read Blog</a>
    </div>
  </section>

  <div class="container">
    <section class="section">
      <div class="section-header">
        <h2>Case Studies</h2>
        <a href="/blog">View all &rarr;</a>
      </div>
      <div class="card-grid">
        {caseStudies.map((post) => (
          <article class="card">
            <h3><a href={`/blog/${post.data.slug}`}>{post.data.title}</a></h3>
            <p class="meta">{formatDate(post.data.date)}</p>
            <p class="excerpt">{getExcerpt(post.body || '', 150)}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Cybersecurity Development Series</h2>
        <a href="/blog">View all &rarr;</a>
      </div>
      <div class="card-grid">
        {devSeries.map((post) => (
          <article class="card">
            <h3><a href={`/blog/${post.data.slug}`}>{post.data.title}</a></h3>
            <p class="meta">{formatDate(post.data.date)}</p>
            <p class="excerpt">{getExcerpt(post.body || '', 150)}</p>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
