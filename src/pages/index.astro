---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Set to true and place a headshot image at public/images/headshot.jpg
const SHOW_PHOTO = true;

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const projectOrder = [
  'devsecops-security-pipeline',
  'have-i-been-pwned-offline-project',
  'resume-tailoring-engine',
  'custom-agent-toolkit',
  'three-day-cybersecurity-challenge',
  'web-application-penetration-testing-project',
  'azure-cloud-architecture-project-secure-web-application-deployment',
  'linux-ctf-privilege-escalation',
];

const caseStudies = allPosts
  .filter((p) => p.data.categories?.includes('projects'))
  .sort((a, b) => {
    const aIdx = projectOrder.indexOf(a.data.slug);
    const bIdx = projectOrder.indexOf(b.data.slug);
    return (aIdx === -1 ? 999 : aIdx) - (bIdx === -1 ? 999 : bIdx);
  })
  .slice(0, 3);

const devSeries = allPosts
  .filter((p) => p.data.categories?.includes('Bootcamp Blog'))
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const tools = [
  { name: 'Password Lab', href: '/tools/passwords', desc: 'Generate and analyze passwords with cryptographic randomness' },
  { name: 'Encryption Suite', href: '/tools/encryption', desc: 'AES + RSA encryption with key pair generation' },
  { name: 'Base Converter', href: '/tools/base-converter', desc: 'Convert numbers between any bases 1\u201336' },
];
---

<BaseLayout title="David Glass | Software Developer & Cybersecurity Professional" description="David Glass — software developer and cybersecurity professional. Portfolio of security projects, interactive tools, and development insights.">
  <section class={`hero ${SHOW_PHOTO ? 'hero-split' : ''}`}>
    {SHOW_PHOTO && (
      <div class="hero-photo">
        <img src="/images/headshot.jpg" alt="David Glass" />
      </div>
    )}
    <div class="hero-content">
      <p class="subtitle"><span class="prompt">~$</span> whoami</p>
      <h1>David Glass</h1>
      <p class="tagline">
        Building secure systems and breaking insecure ones.<br />
        Offensive security and software development. Chicago.
      </p>
      <div class="hero-buttons">
        <a href="/projects" class="btn btn-primary">View Projects</a>
        <a href="/tools" class="btn btn-outline">Tools</a>
      </div>
    </div>
  </section>

  <div class="container">
    <section class="section">
      <div class="section-header">
        <h2>Arsenal</h2>
        <a href="/tools">All tools &rarr;</a>
      </div>
      <div class="tools-grid">
        {tools.map((tool) => (
          <a href={tool.href} class="tool-card">
            <span class="tool-prompt">&gt;</span>
            <div class="tool-info">
              <span class="tool-name">{tool.name}</span>
              <span class="tool-desc">{tool.desc}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Case Studies</h2>
        <a href="/projects">View all &rarr;</a>
      </div>
      <div class="card-grid">
        {caseStudies.map((post) => (
          <article class="card">
            {post.data.description && (
              <p class="outcome-stat">{post.data.description}</p>
            )}
            <h3><a href={`/blog/${post.data.slug}`}>{post.data.title}</a></h3>
            <p class="meta">{formatDate(post.data.date)}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Development Series</h2>
        <a href="/blog">View all &rarr;</a>
      </div>
      <div class="card-grid">
        {devSeries.map((post) => (
          <article class="card">
            <h3><a href={`/blog/${post.data.slug}`}>{post.data.title}</a></h3>
            <p class="meta">{formatDate(post.data.date)}</p>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
