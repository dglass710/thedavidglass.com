---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) =>
  !data.draft && data.categories?.includes('projects')
);

const projectOrder = [
  'three-day-cybersecurity-challenge',
  'soar-lab',
  'devsecops-security-pipeline',
  'drive-reorganization-pipeline',
  'web-application-penetration-testing-project',
  'custom-agent-toolkit',
  'have-i-been-pwned-offline-project',
  'azure-cloud-architecture-project-secure-web-application-deployment',
  'linux-ctf-privilege-escalation',
  'resume-tailoring-engine',
];

const sortedProjects = posts.sort((a, b) => {
  const aIdx = projectOrder.indexOf(a.data.slug);
  const bIdx = projectOrder.indexOf(b.data.slug);
  return (aIdx === -1 ? 999 : aIdx) - (bIdx === -1 ? 999 : bIdx);
});

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Projects | David Glass" description="Cybersecurity projects including penetration testing, cloud architecture, and security tool development by David Glass.">
  <div class="container">
    <div class="page-header">
      <h1>Projects</h1>
      <p>Cybersecurity projects from penetration testing to cloud architecture.</p>
    </div>
    <div class="card-grid">
      {sortedProjects.map((post) => (
        <article class="card">
          {post.data.description && (
            <p class="outcome-stat">{post.data.description}</p>
          )}
          <h3><a href={`/blog/${post.data.slug}`}>{post.data.title}</a></h3>
          <p class="meta">{formatDate(post.data.date)}</p>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
