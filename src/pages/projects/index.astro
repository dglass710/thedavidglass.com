---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) =>
  !data.draft && data.categories?.includes('projects')
);
const sortedProjects = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function getExcerpt(body: string, length = 200): string {
  const cleaned = body
    .replace(/#{1,6}\s/g, '')
    .replace(/\*\*/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_~`]/g, '')
    .trim();
  return cleaned.length > length ? cleaned.slice(0, length) + '...' : cleaned;
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Projects | David Glass" description="Cybersecurity projects including penetration testing, cloud architecture, and security tool development by David Glass.">
  <div class="container">
    <div class="page-header">
      <h1>Projects</h1>
      <p>Cybersecurity projects from penetration testing to cloud architecture.</p>
    </div>
    <div class="card-grid">
      {sortedProjects.map((post) => (
        <article class="card">
          <h3><a href={`/blog/${post.data.slug}`}>{post.data.title}</a></h3>
          <p class="meta">{formatDate(post.data.date)}</p>
          <p class="excerpt">{getExcerpt(post.body || '', 200)}</p>
          <div class="categories">
            <span class="tag">Project</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
