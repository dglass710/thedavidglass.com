---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const pages = await getCollection('pages');
const resumePage = pages.find((p) => p.data.slug === 'resume-builder');

let Content: any = null;
if (resumePage) {
  const rendered = await render(resumePage);
  Content = rendered.Content;
}
---

<BaseLayout title="Resume Builder | David Glass">
  <div class="container">
    <div class="page-header">
      <h1>Resume Builder</h1>
      <p>A desktop app for crafting customized, professional resumes.</p>
    </div>
    <div class="prose">
      {Content && <Content />}
    </div>
  </div>
</BaseLayout>
