---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Password Lab | David Glass">
  <div class="container">
    <div class="page-header">
      <h1>Password Lab</h1>
      <p>Generate secure passwords and test their strength — all in one place.</p>
    </div>

    <div class="tool-panel">
      <div class="tool-section">
        <h2>Generate</h2>
        <div class="charset-toggles">
          <label class="toggle-label">
            <input type="checkbox" id="useLower" checked />
            <span>abc</span>
          </label>
          <label class="toggle-label">
            <input type="checkbox" id="useUpper" checked />
            <span>ABC</span>
          </label>
          <label class="toggle-label">
            <input type="checkbox" id="useDigits" checked />
            <span>123</span>
          </label>
          <label class="toggle-label">
            <input type="checkbox" id="useSpecial" checked />
            <span>#$&</span>
          </label>
        </div>
        <div class="length-control">
          <label for="length">Length</label>
          <input type="range" id="lengthSlider" min="4" max="128" value="20" />
          <input type="number" id="lengthInput" min="4" max="128" value="20" />
        </div>
        <button id="generateBtn" class="btn btn-primary" style="width:100%">Generate Password</button>
      </div>

      <div class="tool-section">
        <h2>Result</h2>
        <div class="password-display">
          <input type="text" id="passwordOutput" readonly placeholder="Your password will appear here" />
          <button id="copyBtn" class="copy-btn" title="Copy to clipboard">Copy</button>
        </div>
        <div class="strength-bar-container">
          <div class="strength-bar" id="strengthBar"></div>
        </div>
        <div class="strength-details" id="strengthDetails"></div>
      </div>

      <div class="tool-section">
        <h2>Test Your Own</h2>
        <p class="tool-note">Type any password to check its strength. Nothing leaves your browser.</p>
        <div class="password-display">
          <input type="password" id="testInput" placeholder="Enter a password to test" />
          <button id="toggleVis" class="copy-btn">Show</button>
        </div>
        <div class="strength-bar-container">
          <div class="strength-bar" id="testStrengthBar"></div>
        </div>
        <div class="strength-details" id="testStrengthDetails"></div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .tool-panel {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .tool-section {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
  }
  .tool-section h2 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .tool-note {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .charset-toggles {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .toggle-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.6rem 1rem;
    cursor: pointer;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.9rem;
    color: var(--text-muted);
    transition: all 0.2s;
    user-select: none;
  }
  .toggle-label:has(input:checked) {
    border-color: var(--accent);
    color: var(--accent-hover);
    background: var(--accent-glow);
  }
  .toggle-label input {
    display: none;
  }
  .length-control {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .length-control label {
    font-size: 0.9rem;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .length-control input[type="range"] {
    flex: 1;
    accent-color: var(--accent);
    height: 6px;
  }
  .length-control input[type="number"] {
    width: 70px;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    padding: 0.5rem;
    font-size: 0.9rem;
    text-align: center;
  }
  .password-display {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .password-display input {
    flex: 1;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    padding: 0.75rem 1rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.95rem;
  }
  .password-display input::placeholder {
    color: var(--text-dim);
  }
  .copy-btn {
    background: var(--bg-surface-hover);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    padding: 0.75rem 1rem;
    cursor: pointer;
    font-size: 0.85rem;
    white-space: nowrap;
    transition: all 0.2s;
  }
  .copy-btn:hover {
    border-color: var(--accent);
    color: var(--accent-hover);
  }
  .strength-bar-container {
    height: 6px;
    background: var(--bg-primary);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  .strength-bar {
    height: 100%;
    width: 0%;
    border-radius: 3px;
    transition: all 0.4s ease;
  }
  .strength-details {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    min-height: 1.5em;
  }
  .strength-details strong {
    color: var(--text);
  }
</style>

<script is:inline>
  const CHARSETS = {
    lower: 'abcdefghijklmnopqrstuvwxyz',
    upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
    digits: '0123456789',
    special: '!@#$%^&*-_+=?~'
  };
  const ATTEMPTS_PER_SEC = 5e10;

  // Sync slider and input
  const slider = document.getElementById('lengthSlider');
  const numInput = document.getElementById('lengthInput');
  slider.addEventListener('input', () => numInput.value = slider.value);
  numInput.addEventListener('input', () => {
    let v = Math.max(4, Math.min(128, parseInt(numInput.value) || 4));
    slider.value = v;
  });

  // Generate password
  document.getElementById('generateBtn').addEventListener('click', () => {
    const checks = {
      lower: document.getElementById('useLower').checked,
      upper: document.getElementById('useUpper').checked,
      digits: document.getElementById('useDigits').checked,
      special: document.getElementById('useSpecial').checked,
    };
    let charset = '';
    for (const [key, on] of Object.entries(checks)) {
      if (on) charset += CHARSETS[key];
    }
    if (!charset) {
      charset = CHARSETS.lower;
      document.getElementById('useLower').checked = true;
    }
    const length = parseInt(numInput.value) || 20;
    const arr = new Uint32Array(length);
    crypto.getRandomValues(arr);
    let password = '';
    for (let i = 0; i < length; i++) {
      password += charset[arr[i] % charset.length];
    }
    const output = document.getElementById('passwordOutput');
    output.value = password;
    analyzeStrength(password, 'strengthBar', 'strengthDetails');
  });

  // Copy
  document.getElementById('copyBtn').addEventListener('click', function() {
    const pw = document.getElementById('passwordOutput').value;
    if (!pw) return;
    navigator.clipboard.writeText(pw).then(() => {
      this.textContent = 'Copied!';
      setTimeout(() => this.textContent = 'Copy', 1500);
    });
  });

  // Test your own
  const testInput = document.getElementById('testInput');
  let debounceTimer;
  testInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      analyzeStrength(testInput.value, 'testStrengthBar', 'testStrengthDetails');
    }, 150);
  });

  // Visibility toggle
  document.getElementById('toggleVis').addEventListener('click', function() {
    const inp = document.getElementById('testInput');
    if (inp.type === 'password') {
      inp.type = 'text';
      this.textContent = 'Hide';
    } else {
      inp.type = 'password';
      this.textContent = 'Show';
    }
  });

  function analyzeStrength(password, barId, detailsId) {
    const bar = document.getElementById(barId);
    const details = document.getElementById(detailsId);
    if (!password) {
      bar.style.width = '0%';
      bar.style.background = 'transparent';
      details.innerHTML = '';
      return;
    }

    let charsetSize = 0;
    let components = [];
    if (/[a-z]/.test(password)) { charsetSize += 26; components.push('lowercase'); }
    if (/[A-Z]/.test(password)) { charsetSize += 26; components.push('uppercase'); }
    if (/\d/.test(password)) { charsetSize += 10; components.push('digits'); }
    if (/[^a-zA-Z0-9]/.test(password)) { charsetSize += 32; components.push('symbols'); }
    if (charsetSize === 0) charsetSize = 1;

    const entropy = Math.log2(Math.pow(charsetSize, password.length));
    const seconds = Math.pow(charsetSize, password.length) / ATTEMPTS_PER_SEC;
    const crackTime = formatTime(seconds);

    // Strength level (0-100)
    const strength = Math.min(100, (entropy / 128) * 100);
    let color, label;
    if (entropy < 28) { color = '#ef4444'; label = 'Very Weak'; }
    else if (entropy < 36) { color = '#f97316'; label = 'Weak'; }
    else if (entropy < 60) { color = '#eab308'; label = 'Fair'; }
    else if (entropy < 80) { color = '#22c55e'; label = 'Strong'; }
    else { color = '#22d3ee'; label = 'Very Strong'; }

    bar.style.width = Math.max(2, strength) + '%';
    bar.style.background = color;
    details.innerHTML = `<strong>${label}</strong> &mdash; ${password.length} chars, ${components.join(' + ')}<br>Entropy: ${entropy.toFixed(1)} bits &middot; Crack time: ${crackTime}`;
  }

  function formatTime(seconds) {
    if (seconds < 0.001) return 'Instant';
    if (seconds < 1) return 'Under a second';
    if (seconds < 60) return Math.floor(seconds) + ' seconds';
    if (seconds < 3600) return Math.floor(seconds / 60) + ' minutes';
    if (seconds < 86400) return Math.floor(seconds / 3600) + ' hours';
    if (seconds < 31536000) return Math.floor(seconds / 86400) + ' days';
    const years = seconds / 31536000;
    if (years < 1000) return Math.floor(years).toLocaleString() + ' years';
    if (years < 1e6) return (years / 1000).toFixed(1) + ' thousand years';
    if (years < 1e9) return (years / 1e6).toFixed(1) + ' million years';
    if (years < 1e12) return (years / 1e9).toFixed(1) + ' billion years';
    return (years / 1e12).toFixed(1) + ' trillion years';
  }
</script>
